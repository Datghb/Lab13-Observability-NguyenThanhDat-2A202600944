APP_NAME=day13-observability-lab
APP_ENV=dev
LOG_LEVEL=INFO
LOG_PATH=data/logs.jsonl
AUDIT_LOG_PATH=data/audit.jsonl

# Fill these in before the Langfuse tracing demo.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
